
ENABLE_RECORDING=1
ENABLE_LIVESTREAMING=1

ENABLE_TRANSCRIPTIONS=1
JIGASI_TRANSCRIBER_ENABLE_TRANSLATION=1
JIGASI_TRANSCRIBER_CUSTOM_SERVICE=org.jitsi.jigasi.transcription.VoskTranscriptionService
JIGASI_TRANSCRIBER_CUSTOM_TRANSLATION_SERVICE=org.jitsi.jigasi.transcription.LibreTranslateTranslationService
TRANSLATION_LANGUAGES=['de', 'hsb']
TRANSLATION_LANGUAGES_HEAD=['de', 'hsb']

JIGASI_TRANSCRIBER_VOSK_URL={"de": "ws://vosk-de:2700", "hsb" : "ws://vosk-hsb-wav2vec2:2700"}

JIGASI_TRANSCRIBER_LIBRETRANSLATE_URL="http://sotra-libretranslate:3000/libretranslate"

JIGASI_TRANSCRIBER_ADVERTISE_URL=true

ASR_SERVER_INTERFACE=0.0.0.0
ASR_SERVER_PORT=2700
ASR_MODEL_NAME=models/Korla/Wav2Vec2BertForCTC-hsb-0
ASR_SAMPLE_RATE=48000
ASR_VERBOSE_OUTPUT=false
ASR_ONNX=false
ASR_USE_LM=false
